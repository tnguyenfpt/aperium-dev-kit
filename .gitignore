# =============================================================================
# Aperium Dev Kit — Repository .gitignore
# =============================================================================

# Local IDE / editor settings
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS generated
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code local settings
.claude/commands/settings.local.json

# Specify framework local state
.specify/memory/

# Superpowers local state (plans, worktrees)
docs/superpowers/plans/

# Test output
test-setup/

# Python
__pycache__/
*.pyc
